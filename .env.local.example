# Resend API key used by src/app/api/contact/route.ts to send contact form
# submissions. Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Sender address for outgoing contact emails. Must be on a domain you have
# verified with Resend (https://resend.com/domains). Until a domain is
# verified, you can leave this unset to use Resend's shared test address
# (onboarding@resend.dev), which only delivers to your own Resend account email.
RESEND_FROM_EMAIL=
